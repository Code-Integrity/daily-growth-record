# --- セキュリティ・認証系 (最優先) ---
src/.env
src/.env.backup
src/.env.production
src/auth.json
*.key
*.pem
*.json

# --- Fortify / AI監査官 (スキャンツール関連) ---
fortify/
target/
reports/
*.fpr
*.log

# --- Laravel / PHP 固有 (src内をガード) ---
src/vendor/
src/node_modules/
src/storage/*.log
src/storage/framework/
src/bootstrap/cache/
src/public/build/
src/public/storage
src/.phpunit.result.cache

# --- Docker / DB の実体隔離 ---
/docker/mysql/data/*
!/docker/mysql/data/.gitkeep

# --- OS / エディタ関連 (本丸の情報を漏らさない) ---
.DS_Store
Thumbs.db
.vscode/
.idea/
.fleet/
.nova/
.zed/
.phpactor.json
Homestead.json
Homestead.yaml